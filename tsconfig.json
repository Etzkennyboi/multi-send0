{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@skill/*": ["skill/*"],
      "@server/*": ["server/*"]
    }
  },
  "include": ["skill/**/*", "server/**/*", "errors.ts"],
  "exclude": ["node_modules", "test", "contracts", "deploy"]
}
