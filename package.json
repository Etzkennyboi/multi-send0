{
  "name": "multi-send-skill",
  "version": "2.1.0",
  "description": "Agent-native multi-send skill for X Layer — batch transfers and transaction bundling.",
  "type": "module",
  "keywords": [
    "multi-send",
    "batch-transfer",
    "x-layer",
    "web3",
    "defi",
    "onchain",
    "agent-native",
    "skills"
  ],
  "author": {
    "name": "Etzkennyboi"
  },
  "files": [
    "skills/",
    "AGENTS.md",
    "CLAUDE.md",
    ".claude-plugin/",
    ".cursor-plugin/"
  ],
  "scripts": {
    "start": "tsx skills/multi-send/index.ts",
    "dev": "tsx watch skills/multi-send/index.ts",
    "send": "tsx skills/multi-send/cli.ts",
    "execute": "tsx skills/multi-send/execute.ts",
    "deploy": "node scripts/deploy.js",
    "deploy:okx": "node scripts/deploy-okx.js",
    "postinstall": "echo '✅ Multi-Send Ready! Quick start: npm run send -- \"send 0.01 USDT to 0x...\"'"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.11.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
