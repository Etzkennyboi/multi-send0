# ── Deployment
PRIVATE_KEY=0x...                 # 32 bytes, NEVER commit to git
GAS_PRICE_GWEI=                   # Optional override (BUG #11 FIX)

# ── Runtime
MULTISEND_ADDRESS=                # Populated after deploy
RPC_URL=https://rpc.xlayer.tech
FALLBACK_RPC_URL=                 # Optional failover (BUG #16 FIX)

# ── Validation
MAX_AMOUNT_WEI=                   # Optional cap override (BUG #09 FIX)

# ── Server
PORT=3000
CORS_ORIGIN=                      # Set explicitly in prod (BUG #07 FIX)
NODE_ENV=development

# ── Verification
XLAYER_API_KEY=                   # OKLink explorer API key
FORK_ENABLED=false                # Set to true for local mainnet fork testing
