# MultiSend Configuration

# Required: Deployed contract address (set automatically by npm run deploy)
# MULTISEND_ADDRESS=0x...

# Required for deployment (choose one):
# Option A: Private key
# PRIVATE_KEY=0xYourPrivateKeyHere

# Option B: OKX Agentic Wallet credentials
# OKX_API_KEY=your_api_key
# OKX_SECRET_KEY=your_secret_key
# OKX_PASSPHRASE=your_passphrase

# Optional: X Layer RPC URL
RPC_URL=https://rpc.xlayer.tech

# USDT on X Layer (pre-configured)
# USDT_ADDRESS=0x1E4a5963aBFD975d8c9021ce480b42188849D41d
